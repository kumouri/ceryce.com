---
interface Props {
  title: string;
  blurb: string;
  /** Short highlight shown as the green badge — usually build time, e.g. "~40 hrs · 3 weekends". */
  metric?: string;
  /** Small label above the title, e.g. "AI-native CRM". */
  category?: string;
  tags?: string[];
  /** External links (repos, live site). The CRM, for example, has two repos. */
  links?: { label: string; href: string }[];
  /** Convenience for a single link; folded into `links`. */
  href?: string;
  linkLabel?: string;
  featured?: boolean;
}

const {
  title,
  blurb,
  metric,
  category,
  tags = [],
  links,
  href,
  linkLabel = 'View project',
  featured = false,
}: Props = Astro.props;

const allLinks = links ?? (href ? [{ label: linkLabel, href }] : []);
---

<article class:list={['card project', { featured }]}>
  {
    (category || metric) && (
      <div class="project-top">
        {category && <span class="project-cat">{category}</span>}
        {metric && <span class="project-metric">{metric}</span>}
      </div>
    )
  }

  <h3>{title}</h3>
  <p class="project-blurb">{blurb}</p>

  {
    tags.length > 0 && (
      <ul class="project-tags">
        {tags.map((t) => (
          <li>{t}</li>
        ))}
      </ul>
    )
  }

  {
    allLinks.length > 0 && (
      <div class="project-links">
        {allLinks.map((l) => (
          <a class="project-link" href={l.href} rel="noopener" target="_blank">
            {l.label} <span aria-hidden="true">↗</span>
          </a>
        ))}
      </div>
    )
  }
</article>

<style>
  .project {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    height: 100%;
  }

  .project-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1rem;
    flex-wrap: wrap;
  }

  .project-cat {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--purple-soft);
  }

  /* The velocity badge — the hook. */
  .project-metric {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--toxic-green);
    background: color-mix(in srgb, var(--toxic-green) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--toxic-green) 35%, transparent);
    border-radius: 999px;
    padding: 0.2rem 0.7rem;
    white-space: nowrap;
  }

  .project h3 {
    color: var(--text);
  }

  .project-blurb {
    color: var(--text-muted);
    font-size: 1rem;
    flex: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .project-tags li {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    background: var(--surface-2);
    border-radius: 4px;
    padding: 0.2rem 0.5rem;
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    margin-top: 0.15rem;
  }

  .project-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--toxic-green);
    text-decoration: none;
  }

  .project-link span {
    display: inline-block;
    transition: transform var(--dur) var(--ease);
  }

  .project-link:hover span {
    transform: translate(2px, -2px);
  }

  /* Featured cards span the full grid row and lean into the brand. */
  .project.featured {
    grid-column: 1 / -1;
    border-color: color-mix(in srgb, var(--kumouri-purple) 45%, var(--border));
    background:
      radial-gradient(120% 140% at 100% 0%, rgba(142, 0, 255, 0.1), transparent 55%),
      var(--surface);
  }

  .project.featured h3 {
    font-size: clamp(1.45rem, 3vw, 1.9rem);
  }

  .project.featured .project-blurb {
    font-size: 1.0625rem;
    max-width: 60ch;
  }
</style>
