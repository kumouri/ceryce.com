---
export const prerender = true; // Static marketing page; only /admin/** is server-rendered.
import BaseLayout from '../layouts/BaseLayout.astro';
import GlitchHeading from '../components/GlitchHeading.astro';

const focus = [
  {
    k: '01',
    title: 'Software engineering',
    body: 'A decade-plus shipping real systems — backends, services, and the unglamorous glue that keeps them running. I care about code that is correct, legible, and kind to the next person who reads it.',
  },
  {
    k: '02',
    title: 'AI architecture',
    body: 'My current obsession: designing how language models, tools, and memory fit together into agents that are actually useful — and that fail safely. Less hype, more systems thinking.',
  },
  {
    k: '03',
    title: 'Building in the open',
    body: 'Assistants, automations, and side projects that scratch a real itch. I like small, sharp tools and I like making the machine do the boring part.',
  },
];
---

<BaseLayout
  title="Ceryce Armstrong"
  description="Ceryce Armstrong — software engineer of 10+ years, now architecting with AI. Personal homepage, portfolio, and résumé."
>
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow">// software engineer · ai architect</p>
      <GlitchHeading as="h1" text="Ceryce Armstrong" class="hero-name" />
      <p class="hero-sub">
        Software engineer of <strong>10+ years</strong>, now architecting with <strong>AI</strong>.
      </p>
      <p class="lead hero-lead">
        I build systems — and, lately, the intelligence inside them. I'm a builder by instinct: give me a
        messy problem and a blank file and I'm happy.
      </p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="/portfolio/">View portfolio</a>
        <a class="btn btn-ghost" href="/resume/">Read résumé</a>
      </div>
    </div>
  </section>

  <section class="focus">
    <div class="container">
      <p class="eyebrow">// what i do</p>
      <div class="focus-grid">
        {
          focus.map((f) => (
            <article class="card focus-card">
              <span class="focus-k">{f.k}</span>
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </article>
          ))
        }
      </div>
      <p class="focus-more">
        More about me on the <a href="/about/">about page</a> — including the parts that aren't on a
        résumé.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: clamp(4rem, 14vh, 9rem) clamp(2rem, 6vh, 4rem);
  }

  .hero-inner {
    max-width: 52rem;
  }

  .hero-name {
    margin-top: 0.75rem;
  }

  .hero-sub {
    margin-top: 1.25rem;
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    color: var(--text);
    font-weight: 500;
  }

  .hero-sub strong {
    color: var(--toxic-green);
    text-shadow: var(--text-glow-green);
  }

  .hero-lead {
    margin-top: 1.25rem;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2.25rem;
  }

  .focus {
    padding-top: 0;
  }

  .focus-grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 1.25rem;
  }

  .focus-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .focus-k {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--kumouri-purple);
    letter-spacing: 0.1em;
  }

  .focus-card h3 {
    color: var(--text);
  }

  .focus-card p {
    color: var(--text-muted);
    font-size: 1rem;
  }

  .focus-more {
    margin-top: 2rem;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }
</style>
