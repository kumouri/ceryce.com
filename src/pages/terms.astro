---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import { marked } from 'marked';
import BaseLayout from '../layouts/BaseLayout.astro';

// Canonical source of truth lives in /legal — render HTML from it, never hand-edit HTML.
// Resolved from the project root (stable during `astro build` and `astro dev`).
const source = readFileSync(join(process.cwd(), 'legal', 'terms-and-conditions.md'), 'utf-8');

// Strip the leading internal-notes HTML comment, then fill the governing-law state.
const cleaned = source
  .replace(/^\s*<!--[\s\S]*?-->\s*/, '')
  .replaceAll('[STATE]', 'Illinois');
const html = marked.parse(cleaned, { async: false }) as string;
---

<BaseLayout
  title="Terms & Conditions"
  description="Terms & Conditions for ceryce.com and the Margo personal-assistant services."
>
  <section class="legal">
    <div class="container">
      <article class="prose" set:html={html} />
    </div>
  </section>
</BaseLayout>

<style>
  .legal {
    padding-block: clamp(3rem, 8vw, 5rem);
  }
</style>
