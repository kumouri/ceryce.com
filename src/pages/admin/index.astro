---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getState, ControlPlaneUnavailable, type DashboardState } from '../../lib/controlPlane';

// Observe view. Server-rendered (no prerender) so it can read live state from
// margo-control with the server-only secrets. Degrades gracefully before the
// control plane is provisioned.
const user = Astro.locals.user?.email;

let state: DashboardState | null = null;
let error: string | null = null;
let unconfigured = false;
try {
  state = await getState();
} catch (err) {
  if (err instanceof ControlPlaneUnavailable) unconfigured = true;
  else error = (err as Error).message;
}

function ago(iso: string | null): string {
  if (!iso) return 'never';
  const ms = Date.now() - new Date(iso).getTime();
  const m = Math.round(ms / 60000);
  if (m < 1) return 'just now';
  if (m < 60) return `${m}m ago`;
  const h = Math.round(m / 60);
  if (h < 24) return `${h}h ago`;
  return `${Math.round(h / 24)}d ago`;
}
const fresh = state?.runnerLastSeen ? Date.now() - new Date(state.runnerLastSeen).getTime() < 15 * 60000 : false;
---

<AdminLayout title="Overview" user={user}>
  <p class="eyebrow">Margo · admin</p>
  <h1>Overview</h1>

  {unconfigured && (
    <div class="panel warn-panel">
      <h2>Control plane not configured</h2>
      <p>Set <code>CONTROL_PLANE_URL</code> + <code>DASH_API_SECRET</code> (and the Access service token)
        as Worker secrets to connect to <code>margo-control</code>. Until then this dashboard has nothing
        to read.</p>
    </div>
  )}
  {error && (
    <div class="panel danger-panel"><h2>Couldn't reach the control plane</h2><p class="mono">{error}</p></div>
  )}

  {state && (
    <>
      <section class="stats" aria-label="Status">
        <div class="stat">
          <span class="stat__k">Runner</span>
          <span class={`stat__v ${fresh ? 'ok' : 'warn'}`}>{fresh ? 'live' : 'stale'} · {ago(state.runnerLastSeen)}</span>
        </div>
        <div class="stat">
          <span class="stat__k">Autonomy</span>
          <span class="stat__v">{state.autonomy.globalMode}</span>
        </div>
        <div class="stat">
          <span class="stat__k">Awaiting you</span>
          <span class={`stat__v ${state.heldApprovals.length ? 'warn' : 'ok'}`}>
            {state.heldApprovals.length} held
          </span>
        </div>
        <div class="stat">
          <span class="stat__k">Runs (recent)</span>
          <span class="stat__v">{state.recentRuns.length}</span>
        </div>
      </section>

      {state.heldApprovals.length > 0 && (
        <p class="cta">
          <a href="/admin/approvals/">{state.heldApprovals.length} draft{state.heldApprovals.length === 1 ? '' : 's'} awaiting approval →</a>
        </p>
      )}

      <section class="panel" aria-label="Recent runs">
        <h2>Recent runs</h2>
        {state.recentRuns.length === 0 ? (
          <p class="muted">No runs mirrored yet. Trigger one from <a href="/admin/trigger/">Trigger</a>.</p>
        ) : (
          <table class="runs">
            <thead><tr><th scope="col">When</th><th scope="col">Mode</th><th scope="col">Status</th><th scope="col">Summary</th></tr></thead>
            <tbody>
              {state.recentRuns.map((r) => (
                <tr>
                  <td class="mono nowrap">{ago(r.date)}</td>
                  <td class="mono">{r.mode}</td>
                  <td class={`mono ${r.status === 'done' ? 'ok' : r.status === 'failed' ? 'danger' : 'warn'}`}>{r.status}</td>
                  <td>{r.notionUrl ? <a href={r.notionUrl} rel="noopener">{r.summary ?? '—'}</a> : (r.summary ?? '—')}</td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </section>
    </>
  )}

  <style>
    .eyebrow { font-family: var(--font-mono); font-size: var(--fs-eyebrow); color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 0.5rem; }
    h1 { font-family: var(--font-display); color: var(--kumouri-purple); margin: 0 0 1.5rem; }
    .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr)); gap: 1rem; }
    .stat { border: 1px solid var(--border); border-radius: var(--radius-lg); background: var(--surface); padding: 1rem 1.25rem; display: flex; flex-direction: column; gap: 0.35rem; }
    .stat__k { font-family: var(--font-mono); font-size: var(--fs-eyebrow); color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.06em; }
    .stat__v { font-family: var(--font-mono); font-size: 1.05rem; color: var(--text); }
    .cta { margin: 1.25rem 0 0; font-family: var(--font-mono); font-size: 0.95rem; }
    .cta a, .runs a { color: var(--toxic-green); }
    .panel { margin-top: 2rem; border: 1px solid var(--border); border-radius: var(--radius-lg); background: var(--surface); padding: 1.25rem 1.5rem; }
    .panel h2 { font-family: var(--font-mono); font-size: var(--fs-eyebrow); text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-dim); margin: 0 0 1rem; }
    .warn-panel { border-color: var(--warn); }
    .danger-panel { border-color: var(--danger); }
    table.runs { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    .runs th { text-align: left; font-family: var(--font-mono); font-size: var(--fs-eyebrow); color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.06em; padding: 0 0.75rem 0.5rem 0; border-bottom: 1px solid var(--border); }
    .runs td { padding: 0.55rem 0.75rem 0.55rem 0; border-bottom: 1px solid var(--border); color: var(--text); vertical-align: top; }
    .mono { font-family: var(--font-mono); }
    .nowrap { white-space: nowrap; }
    .muted { color: var(--text-muted); }
    .ok { color: var(--ok); }
    .warn { color: var(--warn); }
    .danger { color: var(--danger); }
    code { font-family: var(--font-mono); color: var(--toxic-green); }
  </style>
</AdminLayout>
