---
export const prerender = true; // Static marketing page; only /admin/** is server-rendered.
import BaseLayout from '../layouts/BaseLayout.astro';
import GlitchHeading from '../components/GlitchHeading.astro';

/*
  Résumé content. This is a structured template — fill the TODO placeholders with
  real roles, dates, and details. Nothing here is fabricated; the experience entries
  are scaffolding for Ceryce to complete. When a PDF export exists, drop it at
  /public/resume.pdf and the download button below will light up.
*/
const summary =
  "Software engineer with 10+ years of experience building and maintaining production systems, now focused on AI architecture and engineering — designing agentic systems where models, tools, and memory work together reliably.";

type Role = {
  title: string;
  org: string;
  period: string;
  points: string[];
};

const experience: Role[] = [
  {
    title: 'TODO — Role title',
    org: 'TODO — Company',
    period: 'YYYY – Present',
    points: [
      'TODO — a concrete accomplishment with impact (what changed, by how much).',
      'TODO — a system you built or owned, and the technology behind it.',
    ],
  },
  {
    title: 'TODO — Previous role',
    org: 'TODO — Company',
    period: 'YYYY – YYYY',
    points: ['TODO — a result that shows scope and ownership.'],
  },
];

const skillGroups = [
  { label: 'Focus', items: ['AI architecture', 'Agentic systems', 'Backend engineering'] },
  { label: 'TODO — Languages', items: ['TODO', 'TODO'] },
  { label: 'TODO — Tools & platforms', items: ['TODO', 'TODO'] },
];

// Flip to true once /public/resume.pdf exists.
const hasPdf = false;
---

<BaseLayout
  title="Résumé"
  description="Résumé of Ceryce Armstrong — software engineer of 10+ years moving into AI architecture and engineering."
>
  <section class="resume">
    <div class="container resume-inner">
      <div class="resume-top">
        <div>
          <p class="eyebrow">// résumé</p>
          <GlitchHeading as="h1" text="Ceryce Armstrong" />
          <p class="resume-role">Software Engineer · AI Architecture &amp; Engineering</p>
        </div>
        {
          hasPdf ? (
            <a class="btn btn-ghost" href="/resume.pdf" download>
              Download PDF
            </a>
          ) : (
            <span class="btn btn-ghost is-disabled" aria-disabled="true">
              PDF — coming soon
            </span>
          )
        }
      </div>

      <p class="lead resume-summary">{summary}</p>

      <div class="resume-section">
        <h2>Experience</h2>
        <ol class="timeline">
          {
            experience.map((role) => (
              <li class="timeline-item">
                <div class="timeline-head">
                  <h3>
                    {role.title} <span class="at">·</span> <span class="org">{role.org}</span>
                  </h3>
                  <span class="period">{role.period}</span>
                </div>
                <ul class="role-points">
                  {role.points.map((pt) => (
                    <li>{pt}</li>
                  ))}
                </ul>
              </li>
            ))
          }
        </ol>
      </div>

      <div class="resume-section">
        <h2>Skills</h2>
        <div class="skills">
          {
            skillGroups.map((g) => (
              <div class="skill-group">
                <span class="skill-label">{g.label}</span>
                <ul class="skill-items">
                  {g.items.map((s) => (
                    <li>{s}</li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>

      <div class="resume-section">
        <h2>Education</h2>
        <p class="muted">TODO — degree / program, institution, year (or "self-taught" — own it).</p>
      </div>

      <p class="resume-contact">
        Get in touch: <a href="mailto:contact@ceryce.com">contact@ceryce.com</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .resume-inner {
    max-width: 50rem;
  }

  .resume-top {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.25rem;
  }

  .resume-role {
    margin-top: 0.6rem;
    font-family: var(--font-mono);
    color: var(--toxic-green);
    font-size: 0.95rem;
  }

  .is-disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  .resume-summary {
    margin-top: 2rem;
    color: var(--text-muted);
  }

  .resume-section {
    margin-top: 3rem;
  }

  .resume-section h2 {
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.5rem;
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .timeline-item {
    border-left: 2px solid var(--border-bright);
    padding-left: 1.25rem;
    position: relative;
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: -6px;
    top: 0.45rem;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--toxic-green);
    box-shadow: var(--glow-green);
  }

  .timeline-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem 1rem;
  }

  .timeline-head h3 {
    color: var(--text);
  }

  .at {
    color: var(--text-dim);
  }

  .org {
    color: var(--purple-soft);
  }

  .period {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-dim);
  }

  .role-points {
    margin: 0.75rem 0 0;
    padding-left: 1.2rem;
    color: var(--text-muted);
  }

  .role-points li {
    margin-bottom: 0.4rem;
  }

  .role-points li::marker {
    color: var(--kumouri-purple);
  }

  .skills {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
    gap: 1.5rem;
  }

  .skill-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-dim);
    margin-bottom: 0.6rem;
  }

  .skill-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .skill-items li {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text);
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.25rem 0.6rem;
  }

  .muted {
    color: var(--text-dim);
  }

  .resume-contact {
    margin-top: 3rem;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--text-muted);
  }
</style>
